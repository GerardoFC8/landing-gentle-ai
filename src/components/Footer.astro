---
import type { I18nStrings, Locale } from '../i18n/utils'

interface Props {
  locale: Locale
  i18n: I18nStrings
}

const { locale, i18n } = Astro.props

const year = new Date().getFullYear()
---

<footer class="bg-bg-surface border-t border-border-default">
  <div class="max-w-7xl mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-10">

      <!-- Brand column -->
      <div class="md:col-span-1">
        <a
          href={locale === 'en' ? '/' : '/es/'}
          class="flex items-center gap-2 mb-4 group"
          aria-label="Gentle AI — Home"
        >
          <div class="w-8 h-8 rounded-lg overflow-hidden shrink-0">
            <img src="/images/mascot.png" alt="Gentle AI mascot" width="32" height="32" class="w-full h-full object-cover" />
          </div>
          <span class="font-heading font-semibold text-text-primary group-hover:text-accent-primary transition-colors duration-150">
            Gentle AI
          </span>
        </a>
        <p class="text-sm text-text-muted leading-relaxed mb-4">
          {locale === 'en'
            ? 'Production-ready AI agents for the Gentleman Programming ecosystem.'
            : 'Agentes IA listos para producción del ecosistema Gentleman Programming.'}
        </p>
        <div class="flex items-center gap-3">
          <a
            href="https://github.com/Gentleman-Programming/gentle-ai"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-muted hover:text-accent-primary transition-colors duration-150"
            aria-label="GitHub"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
          </a>
          <a
            href="https://discord.com/invite/3QVhF5vRsR"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-muted hover:text-accent-primary transition-colors duration-150"
            aria-label="Discord"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
            </svg>
          </a>
          <a
            href="https://www.youtube.com/@GentlemanProgramming"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-muted hover:text-accent-primary transition-colors duration-150"
            aria-label="YouTube"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Docs links -->
      <div>
        <h3 class="text-sm font-heading font-semibold text-text-primary mb-4">
          {i18n.footer.links.docs.label}
        </h3>
        <ul class="space-y-2">
          {i18n.footer.links.docs.items.map((item) => (
            <li>
              <a
                href={item.url}
                class="text-sm text-text-muted hover:text-accent-primary transition-colors duration-150"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Community links -->
      <div>
        <h3 class="text-sm font-heading font-semibold text-text-primary mb-4">
          {i18n.footer.links.community.label}
        </h3>
        <ul class="space-y-2">
          {i18n.footer.links.community.items.map((item) => (
            <li>
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-text-muted hover:text-accent-primary transition-colors duration-150"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Ecosystem links -->
      <div>
        <h3 class="text-sm font-heading font-semibold text-text-primary mb-4">
          {i18n.footer.links.ecosystem.label}
        </h3>
        <ul class="space-y-2">
          {i18n.footer.links.ecosystem.items.map((item) => (
            <li>
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-text-muted hover:text-accent-primary transition-colors duration-150"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 border-t border-border-default flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-sm text-text-muted">
        © {year} Gentleman Programming.
        <span class="inline-flex items-center gap-1 ml-1">
          <span class="px-1.5 py-0.5 rounded text-xs font-mono bg-bg-elevated border border-border-default text-text-muted">MIT</span>
          License.
        </span>
      </p>
      <p class="text-xs text-text-muted">
        {locale === 'en' ? 'Made with' : 'Hecho con'}
        <span class="text-accent-primary mx-1">♥</span>
        {locale === 'en' ? 'by' : 'por'}
        <a
          href="https://github.com/Gentleman-Programming"
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-muted hover:text-accent-primary transition-colors duration-150 ml-1"
        >
          Alan Buscaglia
        </a>
      </p>
    </div>
  </div>
</footer>
