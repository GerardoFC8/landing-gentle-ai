---
import Section from '../components/Section.astro'
import GlowBlob from '../components/GlowBlob.astro'
import type { I18nStrings, Locale } from '../i18n/utils'

interface Props {
  locale: Locale
  i18n: I18nStrings
}

const { i18n } = Astro.props

const pillarIcons = [
  // Engram — brain/memory
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.44-4.14z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.44-4.14z"/></svg>`,
  // SDD — workflow/map
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 7l6-4 6 4 6-4v14l-6 4-6-4-6 4V7z"/><path d="M9 3v14M15 7v14"/></svg>`,
  // Skills — lightning/expertise
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
]

---

<Section id="solution" class="relative overflow-hidden">
  <GlowBlob color="primary" size="lg" class="-bottom-20 -left-20 opacity-20" />
  <GlowBlob color="secondary" size="md" class="top-0 right-0 opacity-15" />

  <!-- Header -->
  <div class="text-center mb-16 max-w-2xl mx-auto">
    <h2
      class="font-heading font-bold text-3xl sm:text-4xl md:text-5xl text-text-primary mb-4 leading-tight"
      data-animate
    >
      {i18n.solution.headline}
    </h2>
    <p class="text-text-muted text-lg leading-relaxed" data-animate>
      {i18n.solution.intro}
    </p>
  </div>

  <!-- Three pillars -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-stagger>
    {i18n.solution.pillars.map((pillar, index) => (
      <div class="relative flex flex-col gap-5 p-8 rounded-[var(--radius-card)] bg-bg-surface border border-border-default hover:border-accent-primary/40 transition-all duration-300 group">

        <!-- Icon container -->
        <div
          class={`w-14 h-14 rounded-xl flex items-center justify-center text-accent-primary bg-accent-primary/10 group-hover:bg-accent-primary/20 transition-colors duration-300`}
        >
          <Fragment set:html={pillarIcons[index]} />
        </div>

        <!-- Number -->
        <div class="text-xs font-mono text-accent-primary/50 font-semibold tracking-wider">
          {String(index + 1).padStart(2, '0')}
        </div>

        <!-- Content -->
        <div>
          <h3 class="font-heading font-semibold text-text-primary text-xl mb-3 leading-snug">
            {pillar.title}
          </h3>
          <p class="text-text-muted text-sm leading-relaxed">
            {pillar.description}
          </p>
        </div>

        <!-- Bottom accent -->
        <div class="absolute bottom-0 left-8 right-8 h-px bg-gradient-to-r from-transparent via-accent-primary/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
      </div>
    ))}
  </div>
</Section>
