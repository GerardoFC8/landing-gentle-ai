---
import ParticleBackground from '../islands/ParticleBackground.tsx'
import Terminal from '../islands/Terminal.tsx'
import GlowBlob from '../components/GlowBlob.astro'
import Button from '../components/ui/Button.astro'
import Badge from '../components/ui/Badge.astro'
import type { I18nStrings, Locale } from '../i18n/utils'

interface Props {
  locale: Locale
  i18n: I18nStrings
  stats: { stars: number; forks: number; openIssues: number; watchers: number }
  release: { version: string; publishedAt: string; url: string }
}

const { locale, i18n, release } = Astro.props

// Split headline on \n for line breaks
const headlineLines = i18n.hero.headline.split('\n')
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col justify-center overflow-hidden px-6"
>
  <!-- Particle background — triangle-like mesh -->
  <ParticleBackground client:idle />

  <!-- Decorative glow blobs — repositioned for asymmetric layout -->
  <GlowBlob
    color="primary"
    size="lg"
    class="-top-32 left-0 opacity-30"
  />
  <GlowBlob
    color="tertiary"
    size="md"
    class="top-1/2 -right-20 opacity-25"
  />
  <GlowBlob
    color="secondary"
    size="sm"
    class="bottom-32 left-1/3 opacity-20"
  />

  <!-- Subtle gradient mesh background -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 80% 50% at 20% 40%, color-mix(in srgb, var(--color-accent-primary) 4%, transparent), transparent), radial-gradient(ellipse 60% 40% at 80% 60%, color-mix(in srgb, var(--color-accent-secondary) 3%, transparent), transparent);"
    aria-hidden="true"
  />

  <!-- Asymmetric 2-column layout -->
  <div class="relative z-10 max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

    <!-- LEFT: Text content -->
    <div class="flex flex-col gap-8 lg:pr-8">

      <!-- Version badge -->
      <div>
        <a
          href={release.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-2 hover:no-underline"
          aria-label={`${locale === 'en' ? 'Latest release' : 'Última versión'}: ${release.version}`}
        >
          <Badge color="primary">
            <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="opacity-80">
              <path d="M1 7.775V2.75C1 2.06 1.56 1.5 2.25 1.5h5.025c.355 0 .695.14.944.389l6.75 6.75c.527.526.527 1.378 0 1.904l-5.025 5.025c-.526.527-1.378.527-1.904 0l-6.75-6.75A1.336 1.336 0 0 1 1 7.775zm1.5.025 6.75 6.75 5.025-5.025-6.75-6.75H2.5v1.275L8 9.25l-.5.5-5.5-5.5V8z"/>
            </svg>
            {release.version}
            <span class="opacity-60 group-hover:opacity-100 transition-opacity">↗</span>
          </Badge>
          <span class="text-xs text-text-muted">{i18n.hero.badge}</span>
        </a>
      </div>

      <!-- Headline — left-aligned, larger impact -->
      <h1
        class="font-heading font-bold leading-[1.05] tracking-tight text-5xl sm:text-6xl lg:text-7xl xl:text-8xl"
        data-animate
      >
        {headlineLines.map((line, i) => (
          <span class={[
            'block',
            i === 0 && locale === 'es' ? 'whitespace-nowrap' : '',
            i < headlineLines.length - 1
              ? 'text-text-primary'
              : 'bg-gradient-to-r from-accent-primary via-accent-secondary to-accent-primary bg-clip-text text-transparent',
          ].join(' ')}>
            {line}
          </span>
        ))}
      </h1>

      <!-- Subheadline -->
      <p
        class="text-lg sm:text-xl text-text-muted max-w-lg leading-relaxed"
        data-animate
      >
        {i18n.hero.subheadline}
      </p>

      <!-- CTA buttons -->
      <div class="flex flex-col sm:flex-row items-start gap-4">
        <Button href="#install" variant="primary" size="lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          {i18n.hero.ctaInstall}
        </Button>
        <Button
          href="https://github.com/Gentleman-Programming/gentle-ai"
          target="_blank"
          rel="noopener noreferrer"
          variant="secondary"
          size="lg"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          {i18n.hero.ctaGithub}
        </Button>
      </div>
    </div>

    <!-- RIGHT: Terminal — co-star, not afterthought -->
    <div class="w-full flex items-center justify-center lg:justify-end">
      <div class="w-full max-w-xl">
        <Terminal
          client:visible
          commands={i18n.hero.terminalCommands as string[]}
          locale={locale}
        />
      </div>
    </div>

  </div>

  <!-- Bottom fade gradient -->
  <div
    class="absolute bottom-0 left-0 right-0 h-32 pointer-events-none"
    style="background: linear-gradient(to bottom, transparent, var(--bg-base));"
    aria-hidden="true"
  />
</section>
