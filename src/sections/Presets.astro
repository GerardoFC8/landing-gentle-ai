---
import Section from '../components/Section.astro'
import Card from '../components/ui/Card.astro'
import Badge from '../components/ui/Badge.astro'
import CodeBlock from '../components/CodeBlock.astro'
import GlowBlob from '../components/GlowBlob.astro'
import { presets } from '../data/presets'
import type { I18nStrings, Locale } from '../i18n/utils'

interface Props {
  locale: Locale
  i18n: I18nStrings
}

const { locale, i18n } = Astro.props

const tagColor: Record<string, 'primary' | 'secondary' | 'tertiary' | 'neutral'> = {
  recommended: 'primary',
  popular: 'secondary',
  light: 'neutral',
  flexible: 'tertiary',
}

const tagLabel: Record<string, string> = {
  recommended: i18n.presets.recommended,
  popular: i18n.presets.popular,
  light: locale === 'en' ? 'Light' : 'Liviano',
  flexible: locale === 'en' ? 'Flexible' : 'Flexible',
}
---

<Section id="presets" class="relative overflow-hidden">
  <GlowBlob color="tertiary" size="md" class="top-0 -right-10 opacity-15" />

  <!-- Header -->
  <div class="text-center mb-12 max-w-2xl mx-auto">
    <h2
      class="font-heading font-bold text-3xl sm:text-4xl md:text-5xl text-text-primary mb-4 leading-tight"
      data-animate
    >
      {i18n.presets.headline}
    </h2>
    <p class="text-text-muted text-lg leading-relaxed" data-animate>
      {i18n.presets.intro}
    </p>
  </div>

  <!-- Presets grid — pricing-table style -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5" data-stagger>
    {presets.map((preset) => (
      <Card
        class={[
          'flex flex-col p-6 gap-5 relative',
          preset.tag === 'recommended' ? 'ring-1 ring-accent-primary/50' : '',
        ].join(' ')}
      >
        {/* Recommended ribbon */}
        {preset.tag === 'recommended' && (
          <div
            class="absolute -top-px left-0 right-0 h-0.5 bg-gradient-to-r from-transparent via-accent-primary to-transparent"
            aria-hidden="true"
          />
        )}

        <!-- Header -->
        <div class="flex items-start justify-between gap-2">
          <h3 class="font-heading font-semibold text-text-primary text-lg leading-snug">
            {preset.name[locale as 'en' | 'es']}
          </h3>
          <Badge color={tagColor[preset.tag] ?? 'neutral'} class="shrink-0 text-[10px]">
            {tagLabel[preset.tag]}
          </Badge>
        </div>

        <!-- Description -->
        <p class="text-text-muted text-xs leading-relaxed">
          {preset.description[locale as 'en' | 'es']}
        </p>

        <!-- Components list -->
        {preset.components.length > 0 && (
          <div class="flex flex-col gap-1.5">
            <span class="text-xs font-mono text-text-muted/60 uppercase tracking-wider mb-1">
              {locale === 'en' ? 'Includes' : 'Incluye'}
            </span>
            {preset.components.map((comp) => (
              <div class="flex items-center gap-2 text-xs">
                <span class="w-1.5 h-1.5 rounded-full bg-accent-primary/60 shrink-0" aria-hidden="true" />
                <span class="font-mono text-text-primary">{comp}</span>
              </div>
            ))}
            {preset.id === 'custom' && (
              <div class="flex items-center gap-2 text-xs text-text-muted/60 italic">
                {locale === 'en' ? 'Mix and match any components' : 'Combiná los componentes que quieras'}
              </div>
            )}
          </div>
        )}

        <!-- Install command -->
        <div class="mt-auto">
          <CodeBlock
            language="bash"
            code={preset.command}
          />
        </div>
      </Card>
    ))}
  </div>
</Section>
