---
import Section from '../components/Section.astro'
import Button from '../components/ui/Button.astro'
import GlowBlob from '../components/GlowBlob.astro'
import type { I18nStrings, Locale } from '../i18n/utils'

interface Props {
  locale: Locale
  i18n: I18nStrings
}

const { i18n } = Astro.props

const headlineLines = i18n.finalCta.headline.split('\n')
---

<Section id="final-cta" class="relative overflow-hidden">
  <!-- Multiple decorative blobs for full visual saturation -->
  <GlowBlob color="primary" size="lg" class="-top-20 left-1/4 opacity-30" />
  <GlowBlob color="secondary" size="md" class="bottom-0 right-1/4 opacity-25" />
  <GlowBlob color="tertiary" size="sm" class="top-1/2 -left-10 opacity-20" />

  <!-- Full-width visual container -->
  <div
    class="relative rounded-2xl overflow-hidden border border-accent-primary/20 text-center py-20 px-6"
    style="background: linear-gradient(135deg, var(--bg-surface) 0%, color-mix(in srgb, var(--accent-primary) 5%, var(--bg-surface)) 50%, var(--bg-surface) 100%);"
  >
    <!-- Top gradient line -->
    <div
      class="absolute top-0 left-0 right-0 h-px"
      aria-hidden="true"
      style="background: linear-gradient(to right, transparent, var(--accent-primary) 30%, var(--accent-secondary) 70%, transparent); opacity: 0.5;"
    />

    <!-- Headline -->
    <h2
      class="font-heading font-black text-4xl sm:text-5xl md:text-6xl lg:text-7xl leading-tight mb-6 max-w-3xl mx-auto"
      data-animate
    >
      {headlineLines.map((line, i) => (
        <span class={[
          'block',
          i === 0 ? 'text-text-primary' : 'bg-gradient-to-r from-accent-primary to-accent-secondary bg-clip-text text-transparent',
        ].join(' ')}>
          {line}
        </span>
      ))}
    </h2>

    <!-- Subheadline -->
    <p
      class="text-text-muted text-lg sm:text-xl leading-relaxed max-w-2xl mx-auto mb-10"
      data-animate
    >
      {i18n.finalCta.subheadline}
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <Button href="#install" variant="primary" size="lg">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        {i18n.finalCta.ctaInstall}
      </Button>
      <Button
        href="https://github.com/Gentleman-Programming/gentle-ai"
        target="_blank"
        rel="noopener noreferrer"
        variant="secondary"
        size="lg"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
        {i18n.finalCta.ctaGithub}
      </Button>
    </div>

    <!-- Bottom gradient line -->
    <div
      class="absolute bottom-0 left-0 right-0 h-px"
      aria-hidden="true"
      style="background: linear-gradient(to right, transparent, var(--accent-primary) 30%, var(--accent-secondary) 70%, transparent); opacity: 0.3;"
    />
  </div>
</Section>
