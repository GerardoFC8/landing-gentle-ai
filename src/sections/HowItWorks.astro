---
import Section from '../components/Section.astro'
import GlowBlob from '../components/GlowBlob.astro'
import type { I18nStrings, Locale } from '../i18n/utils'

interface Props {
  locale: Locale
  i18n: I18nStrings
}

const { i18n } = Astro.props

const stepIcons = [
  // Download/install
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`,
  // Settings/preset
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93A10 10 0 0 0 4.93 19.07M4.93 4.93A10 10 0 0 1 19.07 19.07"/></svg>`,
  // Agent/bot
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4M8 15h.01M16 15h.01"/></svg>`,
  // Rocket/ship
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>`,
]
---

<Section id="how-it-works" class="relative overflow-hidden">
  <GlowBlob color="secondary" size="lg" class="top-1/2 -translate-y-1/2 -right-20 opacity-20" />

  <!-- Header -->
  <div class="text-center mb-16 max-w-2xl mx-auto">
    <h2
      class="font-heading font-bold text-3xl sm:text-4xl md:text-5xl text-text-primary mb-4 leading-tight"
      data-animate
    >
      {i18n.howItWorks.headline}
    </h2>
  </div>

  <!-- Steps — desktop horizontal timeline / mobile vertical -->
  <div class="relative" data-stagger>
    <!-- Connecting line (desktop only) -->
    <div
      class="hidden md:block absolute top-10 left-[12.5%] right-[12.5%] h-px"
      aria-hidden="true"
      style="background: linear-gradient(to right, transparent, var(--accent-primary) 20%, var(--accent-primary) 80%, transparent); opacity: 0.25;"
    />

    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-6">
      {i18n.howItWorks.steps.map((step, index) => (
        <div class="relative flex flex-col items-center text-center gap-4">
          <!-- Connector for mobile (vertical) -->
          {index < i18n.howItWorks.steps.length - 1 && (
            <div
              class="md:hidden absolute left-1/2 -translate-x-1/2 top-20 w-px h-8 bg-accent-primary/20"
              aria-hidden="true"
            />
          )}

          <!-- Icon circle -->
          <div class="relative z-10 w-20 h-20 rounded-full bg-bg-surface border border-accent-primary/30 flex items-center justify-center text-accent-primary shadow-[var(--shadow-card)]">
            <span><Fragment set:html={stepIcons[index]} /></span>
            <!-- Step dot on connecting line -->
            <div class="absolute -top-0.5 -right-0.5 w-3 h-3 rounded-full bg-accent-primary/60 ring-2 ring-bg-base hidden md:block" aria-hidden="true" />
          </div>

          <!-- Step number -->
          <div class="text-4xl font-heading font-black text-accent-primary/40 leading-none select-none" aria-hidden="true">
            {step.number}
          </div>

          <!-- Content -->
          <div class="flex flex-col gap-2">
            <h3 class="font-heading font-semibold text-text-primary text-lg leading-snug">
              {step.title}
            </h3>
            <p class="text-text-muted text-sm leading-relaxed max-w-xs mx-auto">
              {step.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</Section>
