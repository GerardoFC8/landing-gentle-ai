---
import Section from '../components/Section.astro'
import Card from '../components/ui/Card.astro'
import Badge from '../components/ui/Badge.astro'
import GlowBlob from '../components/GlowBlob.astro'
import { agents } from '../data/agents'
import type { I18nStrings, Locale } from '../i18n/utils'

interface Props {
  locale: Locale
  i18n: I18nStrings
}

const { i18n } = Astro.props
---

<Section id="agents" class="relative overflow-hidden">
  <GlowBlob color="primary" size="md" class="top-0 right-0 opacity-20" />

  <!-- Header -->
  <div class="text-center mb-12 max-w-2xl mx-auto">
    <h2
      class="font-heading font-bold text-3xl sm:text-4xl md:text-5xl text-text-primary mb-4 leading-tight"
      data-animate
    >
      {i18n.agents.headline}
    </h2>
    <p class="text-text-muted text-lg leading-relaxed" data-animate>
      {i18n.agents.intro}
    </p>
  </div>

  <!-- Agents grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5" data-stagger>
    {agents.map((agent) => (
      <a
        href={agent.url}
        target="_blank"
        rel="noopener noreferrer"
        class="group block no-underline"
        aria-label={`${agent.name} — ${i18n.agents.badges[agent.badge]}`}
      >
        <Card class="p-5 flex flex-col gap-4 h-full hover:border-accent-primary/40 transition-all duration-300 group-hover:-translate-y-0.5">
          <!-- Logo + Badge row -->
          <div class="flex items-start justify-between gap-2">
            <div class="w-12 h-12 rounded-lg bg-bg-elevated border border-border-default flex items-center justify-center overflow-hidden shrink-0 agent-logo-wrap">
              <img
                src={agent.logo}
                alt={`${agent.name} logo`}
                width="32"
                height="32"
                class="w-8 h-8 object-contain agent-logo-img"
                loading="lazy"
              />
              <span
                class="agent-logo-fallback hidden text-xl font-heading font-bold text-accent-primary"
                aria-hidden="true"
              >{agent.name.charAt(0)}</span>
            </div>
            <Badge color={agent.badge === 'full' ? 'primary' : 'secondary'} class="shrink-0">
              {agent.badge === 'full' ? '✦ ' : '◆ '}{i18n.agents.badges[agent.badge]}
            </Badge>
          </div>

          <!-- Agent info -->
          <div class="flex flex-col gap-1.5 flex-1">
            <h3 class="font-heading font-semibold text-text-primary text-base leading-snug group-hover:text-accent-primary transition-colors duration-150">
              {agent.name}
            </h3>
            <p class="text-text-muted text-xs leading-relaxed">
              {agent.description}
            </p>
          </div>

          <!-- External link hint -->
          <div class="flex items-center gap-1 text-xs text-text-muted/50 group-hover:text-accent-primary/60 transition-colors duration-150">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
            {agent.url.replace('https://', '').split('/')[0]}
          </div>
        </Card>
      </a>
    ))}
  </div>
</Section>

<script>
  document.querySelectorAll<HTMLImageElement>('.agent-logo-img').forEach((img) => {
    img.addEventListener('error', () => {
      img.style.display = 'none';
      const fallback = img.nextElementSibling as HTMLElement | null;
      if (fallback?.classList.contains('agent-logo-fallback')) {
        fallback.classList.remove('hidden');
      }
    });
  });
</script>
