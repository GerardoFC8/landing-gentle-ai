---
import Section from '../components/Section.astro'
import StatsBar from '../components/StatsBar.astro'
import Button from '../components/ui/Button.astro'
import GlowBlob from '../components/GlowBlob.astro'
import type { I18nStrings, Locale } from '../i18n/utils'

interface Props {
  locale: Locale
  i18n: I18nStrings
  stats: { stars: number; forks: number; openIssues: number; watchers: number }
  release: { version: string; publishedAt: string; url: string }
  contributors: Array<{ login: string; avatarUrl: string; profileUrl: string; contributions: number }>
}

const { locale, i18n, stats, release, contributors } = Astro.props

// Show max 12 contributors
const displayContributors = contributors.slice(0, 12)
---

<Section id="community" class="relative overflow-hidden">
  <GlowBlob color="primary" size="lg" class="-top-10 left-1/2 -translate-x-1/2 opacity-15" />

  <!-- Header -->
  <div class="text-center mb-12 max-w-2xl mx-auto">
    <h2
      class="font-heading font-bold text-3xl sm:text-4xl md:text-5xl text-text-primary mb-4 leading-tight"
      data-animate
    >
      {i18n.community.headline}
    </h2>
    <p class="text-text-muted text-lg leading-relaxed" data-animate>
      {i18n.community.intro}
    </p>
  </div>

  <!-- Stats bar -->
  <div class="mb-16" data-animate>
    <StatsBar
      {stats}
      {release}
      contributors={contributors.length}
      {i18n}
      {locale}
    />
  </div>

  <!-- Contributors -->
  {displayContributors.length > 0 && (
    <div class="mb-12 text-center">
      <h3 class="font-heading font-semibold text-text-primary text-xl mb-6">
        {i18n.community.contributorsLabel}
      </h3>
      <div class="flex flex-wrap justify-center gap-3" data-stagger>
        {displayContributors.map((contributor) => (
          <a
            href={contributor.profileUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col items-center gap-1.5 no-underline"
            title={contributor.login}
            aria-label={`${contributor.login} — ${contributor.contributions} contributions`}
          >
            <div class="w-12 h-12 rounded-full overflow-hidden ring-2 ring-border-default group-hover:ring-accent-primary/60 transition-all duration-200">
              <img
                src={contributor.avatarUrl}
                alt={contributor.login}
                width="48"
                height="48"
                loading="lazy"
                class="w-full h-full object-cover"
              />
            </div>
            <span class="text-xs text-text-muted/70 group-hover:text-accent-primary transition-colors duration-150 max-w-[60px] truncate">
              {contributor.login}
            </span>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- CTAs -->
  <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
    <Button
      href="https://github.com/Gentleman-Programming/gentle-ai"
      target="_blank"
      rel="noopener noreferrer"
      variant="primary"
      size="lg"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
      {locale === 'en' ? 'Star on GitHub' : 'Dar estrella en GitHub'}
    </Button>
    <Button
      href="https://discord.com/invite/3QVhF5vRsR"
      target="_blank"
      rel="noopener noreferrer"
      variant="secondary"
      size="lg"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
      </svg>
      {i18n.community.discord}
    </Button>
  </div>
</Section>
